              "content": "=Lead data:\nName: {{ $json.full_name }}\nEmail: {{ $json.email }}\nPhone: {{ $json.phone }}\nSource: {{ $json.lead_source }}\nMessage: {{ $json.message }}\nProperty type: {{ $json.property_type }}\nArea of interest: {{ $json.area }}\nAd they clicked: {{ $json.ad_name }}\n\nQualify this lead."
